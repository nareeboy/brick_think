{
  "name": "brick-think",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "BrickThink. Virtual Serious Play platform.",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
