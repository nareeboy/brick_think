{
  "name": "brick-think",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "BrickThink. Virtual Serious Play platform.",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "stripe:seed": "tsx scripts/stripe/seed-products.ts",
    "stripe:listen": "stripe listen --forward-to http://localhost:3000/api/stripe/webhook",
    "worker:dev": "tsx watch worker/src/yjs-server.ts",
    "worker:start": "tsx worker/src/yjs-server.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:diff": "supabase db diff --use-migra",
    "db:types": "supabase gen types typescript --local > lib/db/types.generated.ts",
    "db:link": "SUPABASE_ACCESS_TOKEN=$(grep -E '^SUPABASE_ACCESS_TOKEN=' .env.local | cut -d= -f2-) supabase link --project-ref wreypwrvfpzjyijpyhkb",
    "db:migrations": "SUPABASE_ACCESS_TOKEN=$(grep -E '^SUPABASE_ACCESS_TOKEN=' .env.local | cut -d= -f2-) supabase migration list --linked",
    "db:push": "SUPABASE_ACCESS_TOKEN=$(grep -E '^SUPABASE_ACCESS_TOKEN=' .env.local | cut -d= -f2-) supabase db push --linked"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^17.4.2",
    "konva": "^10.0.0",
    "next": "^15.1.6",
    "pg": "^8.20.0",
    "pixi.js": "^8.6.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "stripe": "^22.1.1",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^1.5.4",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@next/eslint-plugin-next": "^15.1.6",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "supabase": "^2.75.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "supabase"
    ]
  }
}
