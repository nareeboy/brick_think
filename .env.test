# E2E env override — points the Next.js build + server at the local Supabase
# stack (`pnpm db:start`) instead of the remote project. Consumed by the
# `build:e2e` / `start:e2e` scripts via dotenv-cli, which playwright.config.ts
# wires into webServer.command.
#
# The JWTs below are the Supabase CLI's well-known demo keys (issuer
# "supabase-demo") — public knowledge, stable across Supabase CLI versions
# and installs. Safe to commit. They only authenticate against a local
# stack listening on 127.0.0.1.
#
# DO NOT put any remote-project secrets here. Real keys belong in `.env.local`
# (gitignored).

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
