# Copy this file to .env.local and fill the values for local development.
# Never commit .env.local. Server-only secrets must not be prefixed with NEXT_PUBLIC_.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public base URL of the deployed site, used to build absolute redirect targets
# (e.g. auth confirm links in roster-actions). Server code prefers this over proxy
# headers. Prod: https://www.brickthink.io. Unset locally → falls back to the
# request's forwarded-host origin (or the hardcoded prod URL in some callers).
NEXT_PUBLIC_SITE_URL=

# Supabase. NEXT_PUBLIC_* vars are exposed to the browser and used by the
# Supabase client; SUPABASE_SERVICE_ROLE_KEY is server-only and bypasses RLS.
# Local: run `pnpm db:start` then `pnpm exec supabase status` to read these.
# Hosted: copy from your project's API settings page.
# SUPABASE_PROJECT_REF is the slug in your project's URL
# (https://<ref>.supabase.co). The `pnpm db:link` script reads it from here
# instead of hardcoding any one project.
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (used by Supabase to sign users in via /sign-in).
# These env vars are NOT read by Next.js directly — they exist as a reminder
# of what's configured in Supabase Dashboard → Authentication → Providers →
# Google. The client ID + secret pair lives there. Single source of truth.
#
# Authorised redirect URIs configured in Google Cloud Console (one entry,
# unchanged across environments — Supabase handles the hop into our app):
#   - https://<your-supabase-project-ref>.supabase.co/auth/v1/callback
#
# Authorized JavaScript origins in Google Cloud Console:
#   - http://localhost:3000     (local dev)
#   - https://www.brickthink.io (production)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Transactional email (Resend). These env vars are NOT read by Next.js — they
# exist as a reminder of what's configured in Supabase Dashboard → Authentication
# → Emails → SMTP Settings (production project) and in supabase/config.toml
# (local stack, currently left on Inbucket at http://127.0.0.1:54324 to avoid
# burning Resend free-tier sends on dev work). Source of truth for the SMTP
# password is the Dashboard, not this file.
#
# In production: Sender email = hello@brickthink.io, sending domain verified at
# Resend with SPF + DKIM + DMARC on Namecheap. See docs/superpowers/followups/
# 2026-05-15-resend-smtp-setup.md (local-only) for the setup runbook.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Worker
# Direct Postgres URL the Yjs worker uses for snapshot persistence.
# Local: postgresql://postgres:postgres@localhost:54322/postgres
# Prod: copy from Supabase project settings > Database > Connection string.
WORKER_DATABASE_URL=

# Yjs WebSocket server URL exposed to the browser.
# Local: ws://localhost:1234/yjs
# Prod: wss://<railway-worker-domain>/yjs
NEXT_PUBLIC_YJS_WS_URL=ws://localhost:1234/yjs

# Shared HMAC secret used by /api/yjs/token to mint and by the Yjs worker
# (worker/src/yjs-server.ts) to verify per-connection auth tokens. Generate
# a fresh value per environment — never reuse across local / preview / prod.
# Rotate by re-deploying both the web service and the worker service with
# the new value. The web side is server-only (NOT prefixed with NEXT_PUBLIC_).
#
# MUST be at least 32 bytes of entropy (64 hex chars) — HS256 derives its
# HMAC key directly from this string, and shorter values weaken the
# signature against offline brute force.
#   openssl rand -hex 32
YJS_JWT_SECRET=

# Feature flag for the Yjs collaborative editor. When '1', session-scoped
# models on the shared_model stage mount the Yjs binding instead of the
# autosave path. NEXT_PUBLIC_ prefix exposes it at client build time.
NEXT_PUBLIC_YJS_COLLAB_ENABLED=

# Local/E2E only — unlocks /api/test/sign-in (used by Playwright fixtures).
# Never set this on Railway. See app/api/test/sign-in/route.ts.
E2E_AUTH_ENABLED=
# Local/E2E only — unlocks /api/test/seed-session (mirror of E2E_AUTH_ENABLED).
# Never set this on Railway. See app/api/test/seed-session/route.ts.
E2E_SESSIONS_ENABLED=

# Optional article byline overrides. JSON array keyed by author email; supplies
# the tagline + links shown beneath an article headline (name + avatar always
# come from the author's profile). Server-only (no NEXT_PUBLIC_ prefix). Unset →
# no overrides. See lib/articles/authors.ts.
#   ARTICLE_AUTHORS='[{"email":"you@example.com","tagline":"…","linkedinUrl":"https://…","portfolioUrl":"https://…"}]'
ARTICLE_AUTHORS=
