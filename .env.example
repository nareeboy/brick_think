# Copy this file to .env.local and fill the values for local development.
# Never commit .env.local. Server-only secrets must not be prefixed with NEXT_PUBLIC_.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test mode in development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Anthropic (server-side only)
ANTHROPIC_API_KEY=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Transactional email (Resend)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Worker
WORKER_DATABASE_URL=
